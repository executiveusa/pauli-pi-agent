# ── Vault source ─────────────────────────────────────────────────────────────
# "github" = reads from a GitHub repo via API (default)
# "tailscale" = reads from local files via Tailscale proxy
VAULT_SOURCE=github

# ── GitHub vault source ───────────────────────────────────────────────────────
# The private (or public) GitHub repo that holds your vault
VAULT_GITHUB_OWNER=executiveusa
VAULT_GITHUB_REPO=mental-models
VAULT_GITHUB_BRANCH=main
# GitHub Personal Access Token with repo:read scope
# Fine-grained token: Contents = Read-only on the vault repo
VAULT_GITHUB_TOKEN=ghp_...

# ── Tailscale vault source ───────────────────────────────────────────────────
# Only needed if VAULT_SOURCE=tailscale
# Run brain-dashboard/tailscale-proxy/server.mjs on your Windows machine / VPS
# then expose it: tailscale funnel 3001
TAILSCALE_PROXY_HOST=your-machine-name.ts.net:3001
TAILSCALE_PROXY_SECRET=change-this-to-a-random-string

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key — only needed for the indexer, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...
