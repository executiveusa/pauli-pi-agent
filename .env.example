# PI Agent Control Plane — Environment Configuration
# Copy this file to .env.local and fill in your actual values for local development
# DO NOT commit .env.local or any file with actual secrets
# For production, use Infisical for centralized secret management

# ============================================================================
# INFISICAL CONFIGURATION (Optional)
# ============================================================================
# Set to 'false' to disable Infisical and use local .env only (development mode)
INFISICAL_ENABLED=false

# Infisical API endpoint
INFISICAL_API_URL=https://app.infisical.com/api

# Infisical service account credentials
# Get these from: https://app.infisical.com/dashboard
INFISICAL_CLIENT_ID=your-client-id
INFISICAL_CLIENT_SECRET=your-client-secret
INFISICAL_PROJECT_ID=your-project-id

# Which Infisical environment to sync from (dev, staging, prod)
INFISICAL_ENVIRONMENT=dev

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string
# Format: postgres://username:password@host:port/database
# Required for application startup
DATABASE_URL=postgres://pi_agent:password@localhost:5432/pi_agent_dev

# Redis for caching (optional)
REDIS_URL=redis://localhost:6379

# ============================================================================
# MODEL PROVIDER API KEYS
# ============================================================================
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# OpenRouter (for free/open models)
OPENROUTER_API_KEY=your-openrouter-key-here

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# Groq (free/fast inference)
GROQ_API_KEY=your-groq-api-key-here

# ============================================================================
# DATA INGESTION & CONTENT ADAPTERS
# ============================================================================
# Firecrawl (web scraping with LLM)
FIRECRAWL_API_KEY=fc-your-firecrawl-key-here

# BrightData (proxy + browser control)
BRIGHTDATA_API_KEY=brd-your-brightdata-key-here

# BrightData browser credentials (if using managed browser)
BRIGHTDATA_BROWSER_USER=your-brightdata-username
BRIGHTDATA_BROWSER_PASS=your-brightdata-password

# ============================================================================
# SPEECH & AUDIO
# ============================================================================
# ElevenLabs or similar TTS provider
SPEECH_API_KEY=your-tts-provider-key-here
SPEECH_PROVIDER=elevenlabs

# ============================================================================
# STORAGE
# ============================================================================
# S3 or S3-compatible storage
S3_BUCKET_NAME=pi-agent-dev
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-s3-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key

# Or use MinIO for local development
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ============================================================================
# AUTHENTICATION & JWT
# ============================================================================
# JWT signing secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# JWT refresh token secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-this-in-production

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Environment: development, staging, production
NODE_ENV=development

# Application port
PORT=3000

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Model routing policy: free, balanced, premium, local_only
PI_MODEL_POLICY=free

# Maximum monthly API budget (USD)
API_BUDGET_MONTHLY=50

# Circuit breaker settings
CIRCUIT_BREAKER_LOOP_LIMIT=10
CIRCUIT_BREAKER_EVIDENCE_GAP_THRESHOLD=3
CIRCUIT_BREAKER_COST_LIMIT_USD=100

# ============================================================================
# OPTIONAL: FEATURES
# ============================================================================
# Enable video analysis module
ENABLE_VIDEO_ANALYSIS=true

# Enable voice interface
ENABLE_VOICE_INTERFACE=true

# Enable dashboard/web UI
ENABLE_DASHBOARD=true

# ============================================================================
# DEVELOPMENT & DEBUG
# ============================================================================
# Debug logging for secret resolution
DEBUG_SECRETS=false

# Disable API calls in tests (always use fixtures)
DISABLE_LIVE_API_CALLS=true

# Database logging (shows SQL queries)
DATABASE_LOG=false

# ============================================================================
# NOTES FOR DEVELOPERS
# ============================================================================
# 1. Never commit .env or .env.local files
# 2. For local development:
#    - Copy this file to .env.local
#    - Fill in at least DATABASE_URL for database connectivity
#    - Provider keys are optional (will use Ollama/free models)
#
# 3. For production deployment:
#    - Use Infisical for centralized secret management
#    - Set INFISICAL_ENABLED=true
#    - Provide Infisical credentials
#    - Do not use .env.local files
#
# 4. Testing:
#    - Tests use fixtures and never make live API calls
#    - Set DISABLE_LIVE_API_CALLS=true in test environments
#
# 5. Required secrets for startup:
#    - DATABASE_URL (critical)
#    - At least one model provider API key (optional, can use free models)
#
# 6. How secrets are resolved (in order):
#    1. Infisical (if enabled and configured)
#    2. Environment variables
#    3. .env.local file
#    4. Missing secret error with remediation steps
