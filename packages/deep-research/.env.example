# Deep Research service environment variables
# Copy to .env and fill in your values

# PostgreSQL connection string (required for Absurd workflow engine)
DATABASE_URL=postgresql://user:password@localhost:5432/deep_research

# Firecrawl API key — get one at https://firecrawl.dev
FIRECRAWL_API_KEY=fc-xxx

# BrightData API key — get one at https://brightdata.com
# Used for geo-diverse web searches (US, Brazil, India, Japan, Nigeria, Germany, etc.)
BRIGHTDATA_API_KEY=xxx

# Anthropic API key — used for the synthesis LLM call
ANTHROPIC_API_KEY=sk-ant-xxx

# HTTP port for the deep-research server (default: 3456)
PORT=3456
