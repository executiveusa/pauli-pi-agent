{
  "name": "YouTube Knowledge Graph Agent",
  "version": "1.0.0",
  "description": "Semantic search and multi-hop reasoning over YouTube",
  "author": "Executive USA",
  "license": "MIT",
  "capabilities": {
    "youtube_search": "Search videos by semantic meaning",
    "youtube_query": "Multi-hop reasoning across library",
    "youtube_concept": "Explore concept hierarchies",
    "youtube_metrics": "View learning metrics"
  },
  "integrations": {
    "mcp_server": true,
    "claude_code": true,
    "cursor_ide": true,
    "windsurf": true
  },
  "settings": {
    "model": "claude-3-5-sonnet-20241022",
    "embedding_dimension": 384,
    "citation_accuracy_target": 0.95,
    "quality_floor": "8.5"
  }
}
