{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PauliVerifiedPartnerCredential",
  "description": "Credential schema for Pauli Sent Me OS verified partners. Uses proof-sdk document provenance for audit trail.",
  "type": "object",
  "properties": {
    "business_name": {
      "type": "string"
    },
    "business_slug": {
      "type": "string"
    },
    "pauli_verified": {
      "type": "boolean"
    },
    "badge_granted_date": {
      "type": "string",
      "format": "date"
    },
    "renewal_date": {
      "type": "string",
      "format": "date"
    },
    "proof_document_slug": {
      "type": "string",
      "description": "proof-sdk document slug containing the full verification audit trail"
    },
    "proof_document_url": {
      "type": "string",
      "description": "Full URL to query partner verification state via proof-sdk HTTP bridge"
    },
    "niche": {
      "type": "string",
      "enum": [
        "real_estate_foreign_buyer",
        "construction_lead_generation",
        "eco_tours_hotels_resorts",
        "plumbers_hvac",
        "anime_digital_products",
        "medical_dental_cosmetic_tourism",
        "destination_weddings_events_retreats",
        "other"
      ]
    },
    "recommended_system": {
      "type": "string"
    },
    "subscription_tier": {
      "type": "string",
      "enum": ["starter", "growth", "premium", "enterprise"]
    },
    "pauli_sent_me_phrase_active": {
      "type": "boolean"
    },
    "qr_code_issued": {
      "type": "boolean"
    },
    "window_sticker_issued": {
      "type": "boolean"
    },
    "directory_page_url": {
      "type": "string"
    },
    "referral_tracking_id": {
      "type": "string"
    }
  },
  "required": [
    "business_name",
    "business_slug",
    "pauli_verified",
    "badge_granted_date",
    "proof_document_slug",
    "niche"
  ]
}
